# Copy this file to `.env` and adjust values for your environment.

# Path to the SQLite database file used by the API and Streamlit app.
VLC_DB_PATH=./data/virtuallab.db

# Random seed used by the synthetic data generator (deterministic output).
VLC_RANDOM_SEED=42

# Number of synthetic patients to generate when seeding the database.
VLC_NUM_PATIENTS=400

# Base URL the Streamlit frontend uses to call the FastAPI backend.
VLC_API_BASE_URL=http://localhost:8000

# FastAPI bind host/port.
VLC_API_HOST=0.0.0.0
VLC_API_PORT=8000

# Optional LLM hook (left disabled in this prototype).
# When VLC_LLM_PROVIDER is set the parser will dispatch to a future LLM
# adapter under src/parser/llm_adapter.py. Leave blank to use rules only.
VLC_LLM_PROVIDER=
VLC_LLM_API_KEY=
